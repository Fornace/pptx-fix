{
  "name": "pptx-fix",
  "version": "0.3.0",
  "description": "Fix PowerPoint files that render incorrectly on macOS QuickLook and iOS — resolves missing table borders, invisible shapes, flattened gradients, and opaque blocks caused by OfficeImport rendering gaps.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pptx-fix": "dist/cli.js"
  },
  "keywords": [
    "pptx",
    "powerpoint",
    "quicklook",
    "macos",
    "ios",
    "fix",
    "repair",
    "officeimport",
    "ooxml",
    "office-open-xml",
    "table-styles",
    "python-pptx",
    "pptxgenjs",
    "presentation",
    "apple",
    "preview",
    "slides",
    "iphone",
    "ipad",
    "finder",
    "thumbnail",
    "table-borders",
    "shapes",
    "gradients",
    "rendering",
    "google-slides",
    "canva",
    "libreoffice",
    "pandoc",
    "cross-platform",
    "compatibility"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.2.0",
    "jszip": "^3.10.1",
    "quicklook-pptx-renderer": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
